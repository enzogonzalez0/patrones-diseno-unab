        return "Botón 'X' presionado en el joystick de Play."

class AdaptadorParaXbox:
    def __init__(self, joystick_play):
        self.joystick_play = joystick_play
    def apretar_boton_a(self):
        accion_real = self.joystick_play.apretar_boton_equis()
        return f"Adaptador traduciendo: [{accion_real}] -> Convertido a Botón 'A' de Xbox."


 #3 strategy 

 class DescuentoNormal:
    def calcular(self, total):
        return total

class DescuentoBlackFriday:
    def calcular(self, total):
        return total * 0.5

class CarritoDeCompras:
    def __init__(self, estrategia_descuento):
        self.total = 1000
        self.estrategia = estrategia_descuento

    def pagar(self):
        total_final = self.estrategia.calcular(self.total)
        return f"El total a pagar es: ${total_final}"

